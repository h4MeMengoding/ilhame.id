{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:next": {
      "outputs": [".next/**", "!.next/cache/**"],
      "cache": true,
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_*",
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET",
        "SPOTIFY_CLIENT_ID",
        "SPOTIFY_CLIENT_SECRET",
        "SPOTIFY_REFRESH_TOKEN",
        "FIREBASE_API_KEY",
        "FIREBASE_AUTH_DOMAIN",
        "FIREBASE_PROJECT_ID",
        "FIREBASE_STORAGE_BUCKET",
        "FIREBASE_MESSAGING_SENDER_ID",
        "FIREBASE_APP_ID",
        "FIREBASE_MEASUREMENT_ID",
        "NEXT_PUBLIC_SITE_KEY",
        "TURNSTILE_SECRET_KEY",
        "OPENAI_API_KEY",
        "SUPABASE_URL",
        "SUPABASE_KEY"
      ],
      "inputs": [
        "src/**",
        "public/**",
        "prisma/**",
        "next.config.js",
        "tailwind.config.js",
        "postcss.config.js",
        "tsconfig.json",
        "package.json"
      ]
    }
  },
  "globalDependencies": [".env", ".env.local", ".env.production"],
  "globalEnv": ["NODE_ENV"]
}
